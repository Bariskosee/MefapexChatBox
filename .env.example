# MEFAPEX Chatbot Environment Variables
# .env dosyasını oluşturmak için bu dosyayı kopyalayın ve gerçek değerlerle doldurun
# cp .env.example .env

# 🔐 SECURITY SETTINGS (IMPORTANT!)
SECRET_KEY=your-very-secure-secret-key-change-this-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 🤖 AI CONFIGURATION
USE_OPENAI=false
USE_HUGGINGFACE=true

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face Model Selection (choose one)
HUGGINGFACE_MODEL=microsoft/DialoGPT-small
# Options:
# microsoft/DialoGPT-small       # 117M params - Fast, good conversations
# microsoft/DialoGPT-medium      # 354M params - Better quality, slower  
# facebook/blenderbot_small-90M  # 90M params - Good for chatbots
# gpt2                          # 124M params - General text generation
# google/flan-t5-small          # 80M params - Instruction following

# Qdrant Vector Database Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# MySQL Database Configuration (optional)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=mefapex_chatbot

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
